+static int create_memfd_file( file_pos_t size )
+{
+    int fd;
+    
+    if (overcommit_prevention_enabled() && memory_available_for_commit(size) == FALSE)
+    {
+        set_error(STATUS_NO_MEMORY);
+        return -1;
+    }
